{% comment %}
  Logo list / brand trust section.
{% endcomment %}

<section class="so-section" id="shopify-section-{{ section.id }}">
  <div class="so-page-width">
    {% if section.settings.heading != blank %}
      <h2 class="so-section__heading" style="font-size:var(--so-text-lg); text-align:center; margin-bottom:var(--so-space-lg);">
        {{ section.settings.heading | escape }}
      </h2>
    {% endif %}

    <div class="so-logo-list" style="display:flex; flex-wrap:wrap; gap:var(--so-space-2xl) var(--so-space-3xl); justify-content:center; align-items:center; opacity:0.6;">
      {% for block in section.blocks %}
        {% if block.settings.logo != blank %}
          <div class="so-logo-list__item" {% render 'block-shopify-attrs', block: block %}>
            {% if block.settings.link != blank %}
              <a href="{{ block.settings.link }}" aria-label="{{ block.settings.logo.alt | default: 'Logo' | escape }}" target="_blank" rel="noopener">
                {% render 'responsive-image', image: block.settings.logo, class: '', alt: block.settings.logo.alt, style: 'height:' | append: block.settings.logo_height | append: 'px; width:auto; object-fit:contain;' %}
              </a>
            {% else %}
              {% render 'responsive-image', image: block.settings.logo, class: '', alt: block.settings.logo.alt, style: 'height:' | append: block.settings.logo_height | append: 'px; width:auto; object-fit:contain;' %}
            {% endif %}
          </div>
        {% elsif block.settings.text != blank %}
          <div class="so-logo-list__item so-logo-list__text" style="font-weight:700; font-size:var(--so-text-lg); color:var(--so-color-text-faint); letter-spacing:var(--so-tracking-tight);" {% render 'block-shopify-attrs', block: block %}>
            {{ block.settings.text | escape }}
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Logo list",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading" },
    { "type": "range", "id": "logo_height", "label": "Logo height (px)", "min": 20, "max": 60, "step": 4, "default": 32 }
  ],
  "blocks": [
    {
      "type": "logo",
      "name": "Logo",
      "settings": [
        { "type": "image_picker", "id": "logo", "label": "Logo" },
        { "type": "url", "id": "link", "label": "Link" },
        { "type": "text", "id": "text", "label": "Text fallback (if no logo)" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Logo list",
      "blocks": [
        { "type": "logo" },
        { "type": "logo" },
        { "type": "logo" },
        { "type": "logo" }
      ]
    }
  ]
}
{% endschema %}
