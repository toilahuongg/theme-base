{% liquid
  assign featured_collection = section.settings.collection | default: collection
%}

<section class="so-section">
  <div class="so-page-width">
    <div class="so-section__header">
      <h2 class="so-section__heading">
        {% if section.settings.heading != blank %}
          {{ section.settings.heading | escape }}
        {% elsif featured_collection != blank %}
          {{ featured_collection.title | escape }}
        {% else %}
          Featured products
        {% endif %}
      </h2>
      {% if section.settings.text != blank %}
        <div class="so-section__text rte">{{ section.settings.text }}</div>
      {% endif %}
    </div>

    {% if featured_collection != blank and featured_collection.products.size > 0 %}
      <div class="so-grid so-product-grid">
        {% for product in featured_collection.products limit: section.settings.products_to_show %}
          {% render 'product-card', product: product %}
        {% endfor %}
      </div>
    {% else %}
      <p class="so-section__text">{{ 'sections.featured_products.empty' | t }}</p>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Featured products",
  "settings": [
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Featured products"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text",
      "default": "<p>Show a small product grid to keep the home page focused.</p>"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "label": "Products to show",
      "min": 2,
      "max": 8,
      "step": 1,
      "default": 4
    }
  ],
  "presets": [
    {
      "name": "Featured products"
    }
  ]
}
{% endschema %}
