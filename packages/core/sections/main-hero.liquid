<section class="tb-section tb-hero">
  <div class="tb-page-width tb-hero__inner">
    {% if section.settings.eyebrow != blank %}
      <p class="tb-hero__eyebrow">{{ section.settings.eyebrow }}</p>
    {% endif %}

    {% if section.settings.heading != blank %}
      <h1 class="tb-hero__heading">{{ section.settings.heading }}</h1>
    {% endif %}

    {% if section.settings.text != blank %}
      <div class="tb-hero__text rte">{{ section.settings.text }}</div>
    {% endif %}

    {% if section.settings.button_label != blank %}
      <div>
        {% render 'button',
          label: section.settings.button_label,
          url: section.settings.button_url,
          secondary: false
        %}
      </div>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Main hero",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "New collection"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Build a storefront that feels considered from day one."
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text",
      "default": "<p>Theme Base gives you reusable theme source files that stay clean, accessible, and easy to extend.</p>"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Shop now"
    },
    {
      "type": "url",
      "id": "button_url",
      "label": "Button link"
    }
  ],
  "presets": [
    {
      "name": "Main hero"
    }
  ]
}
{% endschema %}
