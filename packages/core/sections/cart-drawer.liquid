<so-cart-drawer class="so-cart-drawer" id="cart-drawer" trigger-selector="[data-cart-drawer-trigger]">
  <div class="so-cart-drawer__panel" data-cart-drawer-panel hidden>
    <header class="so-cart-drawer__header">
      <h2 class="so-cart-drawer__title">{{ 'cart.general.title' | t }}</h2>
      <button class="so-cart-drawer__close" type="button" data-cart-drawer-close aria-label="{{ 'cart.general.close' | t }}">
        {{ 'cart.general.close' | t }}
      </button>
    </header>

    <so-cart-items class="so-cart-drawer__items" currency="{{ cart.currency.iso_code | default: shop.currency }}">
      <ul class="so-cart-lines" role="list" data-cart-lines {% if cart.item_count == 0 %}hidden{% endif %}>
        {% for item in cart.items %}
          {% render 'cart-line-item', item: item, line_index: forloop.index %}
        {% endfor %}
      </ul>
      <p class="so-cart-drawer__empty" data-cart-empty {% if cart.item_count > 0 %}hidden{% endif %}>{{ 'cart.general.empty' | t }}</p>
    </so-cart-items>

    <footer class="so-cart-drawer__footer" data-cart-summary {% if cart.item_count == 0 %}hidden{% endif %}>
      <div class="so-cart-drawer__subtotal">
        <span>{{ 'cart.general.subtotal' | t }}</span>
        <strong data-cart-subtotal>{{ cart.total_price | money }}</strong>
      </div>
      <a class="so-button" href="{{ routes.cart_url }}">{{ 'cart.general.view_cart' | t }}</a>
      <a class="so-button so-button--secondary" href="{{ routes.checkout_url }}">{{ 'cart.general.checkout' | t }}</a>
    </footer>
  </div>
</so-cart-drawer>

{% schema %}
{
  "name": "Cart drawer"
}
{% endschema %}
