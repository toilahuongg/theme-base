{% comment %}
  Testimonials section with carousel support.
{% endcomment %}

<section class="so-section so-testimonials" id="shopify-section-{{ section.id }}">
  <div class="so-page-width">
    {% if section.settings.heading != blank %}
      <div class="so-section__header">
        <h2 class="so-section__heading">{{ section.settings.heading | escape }}</h2>
      </div>
    {% endif %}

    {% if section.settings.enable_carousel and section.blocks.size > 1 %}
      <so-carousel class="so-carousel" {% if section.settings.autoplay %}autoplay{% endif %} pause-on-hover>
        <button class="so-carousel__button so-carousel__prev" data-carousel-prev aria-label="{{ 'general.carousel.previous' | t }}">&larr;</button>
        <div class="so-carousel__track" data-carousel-track>
          {% for block in section.blocks %}
            <div class="so-carousel__item" data-carousel-slide>
              {% render 'testimonial-card', block: block %}
            </div>
          {% endfor %}
        </div>
        <button class="so-carousel__button so-carousel__next" data-carousel-next aria-label="{{ 'general.carousel.next' | t }}">&rarr;</button>
      </so-carousel>
    {% else %}
      <div class="so-grid so-product-grid">
        {% for block in section.blocks %}
          <div class="so-card" style="padding:var(--so-space-lg);">
            {% render 'testimonial-card', block: block %}
          </div>
        {% endfor %}
      </div>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Testimonials",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "What our customers say" },
    { "type": "checkbox", "id": "enable_carousel", "label": "Enable carousel", "default": true },
    { "type": "checkbox", "id": "autoplay", "label": "Autoplay carousel", "default": false }
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "Testimonial",
      "settings": [
        { "type": "textarea", "id": "quote", "label": "Quote", "default": "Great product, fast shipping." },
        { "type": "text", "id": "author", "label": "Author name", "default": "A customer" },
        { "type": "text", "id": "role", "label": "Role / Title" },
        { "type": "image_picker", "id": "avatar", "label": "Avatar image" },
        { "type": "range", "id": "rating", "label": "Rating", "min": 0, "max": 5, "step": 1, "default": 5 }
      ]
    }
  ],
  "presets": [
    {
      "name": "Testimonials",
      "blocks": [
        { "type": "testimonial" },
        { "type": "testimonial" },
        { "type": "testimonial" }
      ]
    }
  ]
}
{% endschema %}
