{% comment %}
  Footer section with links, social, and newsletter.
{% endcomment %}

<footer class="so-footer" role="contentinfo">
  <div class="so-page-width">
    <div class="so-footer__inner">
      {% for block in section.blocks %}
        {% case block.type %}
          {% when 'links' %}
            <div class="so-footer__column">
              <h3>{{ block.settings.heading | escape }}</h3>
              <ul class="so-footer__links">
                {% for link in block.settings.menu.links %}
                  <li>
                    <a href="{{ link.url }}">{{ link.title | escape }}</a>
                  </li>
                {% endfor %}
              </ul>
            </div>

          {% when 'newsletter' %}
            <div class="so-footer__column">
              <h3>{{ block.settings.heading | escape }}</h3>
              {% form 'customer', class: 'so-newsletter' %}
                {{ form.errors | default_errors }}
                <div class="so-newsletter__form">
                  <input
                    type="email"
                    name="contact[email]"
                    class="so-newsletter__input"
                    placeholder="{{ 'newsletter.placeholder' | t }}"
                    aria-label="{{ 'newsletter.placeholder' | t }}"
                    required
                  >
                  <button class="so-button" type="submit">{{ 'newsletter.subscribe' | t }}</button>
                </div>
                {% if form.posted_successfully? %}
                  <p class="so-newsletter__success">{{ 'newsletter.success' | t }}</p>
                {% endif %}
              {% endform %}
            </div>

          {% when 'social' %}
            <div class="so-footer__column">
              <h3>{{ block.settings.heading | escape }}</h3>
              <div class="so-footer__social">
                {% if block.settings.social_facebook != blank %}
                  <a href="{{ block.settings.social_facebook }}" aria-label="Facebook" target="_blank" rel="noopener">
                    {{ 'general.social.facebook' | t }}
                  </a>
                {% endif %}
                {% if block.settings.social_instagram != blank %}
                  <a href="{{ block.settings.social_instagram }}" aria-label="Instagram" target="_blank" rel="noopener">
                    {{ 'general.social.instagram' | t }}
                  </a>
                {% endif %}
                {% if block.settings.social_twitter != blank %}
                  <a href="{{ block.settings.social_twitter }}" aria-label="Twitter" target="_blank" rel="noopener">
                    {{ 'general.social.twitter' | t }}
                  </a>
                {% endif %}
              </div>
            </div>
        {% endcase %}
      {% endfor %}
    </div>

    <div class="so-footer__bottom">
      <p>&copy; {{ 'now' | date: '%Y' }} {{ shop.name | escape }}. {{ 'footer.all_rights' | t }}</p>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "tag": "section",
  "blocks": [
    {
      "type": "links",
      "name": "Link column",
      "settings": [
        { "type": "text", "id": "heading", "label": "Heading", "default": "Shop" },
        { "type": "link_list", "id": "menu", "label": "Menu" }
      ]
    },
    {
      "type": "newsletter",
      "name": "Newsletter",
      "settings": [
        { "type": "text", "id": "heading", "label": "Heading", "default": "Stay updated" }
      ]
    },
    {
      "type": "social",
      "name": "Social links",
      "settings": [
        { "type": "text", "id": "heading", "label": "Heading", "default": "Follow us" },
        { "type": "text", "id": "social_facebook", "label": "Facebook URL" },
        { "type": "text", "id": "social_instagram", "label": "Instagram URL" },
        { "type": "text", "id": "social_twitter", "label": "Twitter URL" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Footer",
      "blocks": [
        { "type": "links" },
        { "type": "links" },
        { "type": "newsletter" },
        { "type": "social" }
      ]
    }
  ]
}
{% endschema %}
