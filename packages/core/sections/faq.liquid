{% comment %}
  FAQ section using so-accordion.
{% endcomment %}

<section class="so-section" id="shopify-section-{{ section.id }}">
  <div class="so-page-width">
    {% if section.settings.heading != blank %}
      <div class="so-section__header">
        <h2 class="so-section__heading">{{ section.settings.heading | escape }}</h2>
        {% if section.settings.subheading != blank %}
          <p class="so-section__text">{{ section.settings.subheading | escape }}</p>
        {% endif %}
      </div>
    {% endif %}

    <so-accordion class="so-accordion" {% if section.settings.single_expand %}single-expand{% endif %}>
      {% for block in section.blocks %}
        <div class="so-accordion__item" data-accordion-item {% render 'block-shopify-attrs', block: block %}>
          <button class="so-accordion__toggle" data-accordion-toggle aria-expanded="{% if block.settings.open %}true{% else %}false{% endif %}">
            {{ block.settings.question | escape }}
          </button>
          <div class="so-accordion__panel" data-accordion-panel {% unless block.settings.open %}hidden{% endunless %}>
            <div class="rte">
              {{ block.settings.answer }}
            </div>
          </div>
        </div>
      {% endfor %}
    </so-accordion>
  </div>
</section>

{% schema %}
{
  "name": "FAQ",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Frequently asked questions" },
    { "type": "text", "id": "subheading", "label": "Subheading" },
    { "type": "checkbox", "id": "single_expand", "label": "Only one open at a time", "default": true }
  ],
  "blocks": [
    {
      "type": "question",
      "name": "Question",
      "settings": [
        { "type": "text", "id": "question", "label": "Question", "default": "What is your return policy?" },
        { "type": "richtext", "id": "answer", "label": "Answer", "default": "<p>You can return items within 30 days of delivery.</p>" },
        { "type": "checkbox", "id": "open", "label": "Open by default", "default": false }
      ]
    }
  ],
  "presets": [
    {
      "name": "FAQ",
      "blocks": [
        { "type": "question" },
        { "type": "question" },
        { "type": "question" }
      ]
    }
  ]
}
{% endschema %}
