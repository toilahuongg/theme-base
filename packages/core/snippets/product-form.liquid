{% comment %}
  @param product {product}
  @param section_id {string}
  @param ajax {boolean}
{% endcomment %}

{% if product != blank %}
  {% assign current_variant = product.selected_or_first_available_variant %}
  {% assign product_form_id = 'so-product-form-' | append: section_id %}

  <so-product-form{% if ajax %} ajax{% endif %}>
    {% form 'product', product, id: product_form_id, class: 'so-product-form' %}
      <input type="hidden" name="id" value="{{ current_variant.id }}">

      <div class="so-product-form__quantity">
        <label class="so-product-form__label" for="{{ product_form_id }}-quantity">
          {{ 'products.product.quantity' | t }}
        </label>
        <so-quantity class="so-quantity">
          <button
            class="so-quantity__button"
            type="button"
            data-quantity-decrease
            aria-label="{{ 'products.product.decrease_quantity' | t | escape }}"
          >
            -
          </button>
          <input
            id="{{ product_form_id }}-quantity"
            class="so-quantity__input"
            type="number"
            name="quantity"
            min="1"
            step="1"
            value="1"
            aria-label="{{ 'products.product.quantity' | t | escape }}"
          >
          <button
            class="so-quantity__button"
            type="button"
            data-quantity-increase
            aria-label="{{ 'products.product.increase_quantity' | t | escape }}"
          >
            +
          </button>
        </so-quantity>
      </div>

      <div class="so-product-form__actions">
        <button
          class="so-button so-product-form__submit"
          type="submit"
          data-add-to-cart-text="{{ 'products.product.add_to_cart' | t | escape }}"
          data-sold-out-text="{{ 'products.product.sold_out' | t | escape }}"
          data-unavailable-text="{{ 'products.product.unavailable' | t | escape }}"
          {% unless current_variant.available %}disabled{% endunless %}
        >
          {% if current_variant.available %}
            {{ 'products.product.add_to_cart' | t }}
          {% else %}
            {{ 'products.product.sold_out' | t }}
          {% endif %}
        </button>
      </div>
    {% endform %}
  </so-product-form>
{% endif %}
