{% comment %}
  @param paginate {object} Shopify paginate object
  @param aria_label {string} Accessibility label
{% endcomment %}

{% if paginate.pages > 1 %}
  <nav aria-label="{{ aria_label | default: 'general.pagination' | t }}">
    <ol class="so-pagination">
      {% if paginate.previous %}
        <li>
          <a class="so-pagination__link" href="{{ paginate.previous.url }}" aria-label="{{ 'general.pagination.previous' | t }}">
            &larr;
          </a>
        </li>
      {% else %}
        <li>
          <span class="so-pagination__link" disabled aria-label="{{ 'general.pagination.previous' | t }}">&larr;</span>
        </li>
      {% endif %}

      {% for part in paginate.parts %}
        {% if part.is_link %}
          <li>
            <a class="so-pagination__link" href="{{ part.url }}">{{ part.title }}</a>
          </li>
        {% else %}
          <li>
            <span class="so-pagination__link" aria-current="page">{{ part.title }}</span>
          </li>
        {% endif %}
      {% endfor %}

      {% if paginate.next %}
        <li>
          <a class="so-pagination__link" href="{{ paginate.next.url }}" aria-label="{{ 'general.pagination.next' | t }}">
            &rarr;
          </a>
        </li>
      {% else %}
        <li>
          <span class="so-pagination__link" disabled aria-label="{{ 'general.pagination.next' | t }}">&rarr;</span>
        </li>
      {% endif %}
    </ol>
  </nav>
{% endif %}
