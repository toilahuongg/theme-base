{% comment %}
  @param product {product} Shopify product object
  @param variant_id {number} Variant ID to check availability for
{% endcomment %}

{% assign variant = product.variants | where: 'id', variant_id | first %}
{% if variant == blank %}
  {% assign variant = product.selected_or_first_available_variant %}
{% endif %}

{% if variant.available and shop.pickup_enabled %}
  <div class="so-pickup-availability">
    <h3 class="so-pickup-availability__title">{{ 'products.product.pickup_availability.title' | t }}</h3>

    {% if shop.locations.size > 0 %}
      {% for location in shop.locations limit: 3 %}
        {% if location.available_for_pickup and location.inventory_level.stock_quantity > 0 %}
          <div class="so-pickup-availability__location">
            <p class="so-pickup-availability__name">{{ location.name | escape }}</p>
            <p class="so-pickup-availability__address">
              {{ location.address | format_address }}
            </p>
            {% if location.inventory_level.stock_quantity > 5 %}
              <p class="so-pickup-availability__status" style="color: var(--so-color-success)">
                {{ 'products.product.pickup_availability.in_stock' | t }}
              </p>
            {% else %}
              <p class="so-pickup-availability__status" style="color: var(--so-color-warning)">
                {{ 'products.product.pickup_availability.low_stock' | t }}
              </p>
            {% endif %}
          </div>
        {% endif %}
      {% endfor %}
    {% else %}
      <p class="so-pickup-availability__empty">
        {{ 'products.product.pickup_availability.no_locations' | t }}
      </p>
    {% endif %}
  </div>
{% endif %}
