{% comment %}
  @param toggle_text {string} Toggle button label
  @param content {string} Panel content (HTML)
  @param open {boolean} Initially expanded
  @param class {string} Additional CSS classes
{% endcomment %}

<div class="so-disclosure {{ class }}">
  <button class="so-disclosure__toggle" data-disclosure-toggle aria-expanded="{% if open %}true{% else %}false{% endif %}">
    {{ toggle_text | escape }}
  </button>
  <div class="so-disclosure__panel" data-disclosure-panel {% unless open %}hidden{% endunless %}>
    {{ content }}
  </div>
</div>
