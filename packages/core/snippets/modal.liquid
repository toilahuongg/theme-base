{% comment %}
  @param trigger_selector {string} CSS selector for elements that open the modal
  @param title {string} Modal heading
  @param content {string} Modal body content (HTML)
  @param id {string} Unique modal identifier
{% endcomment %}

<so-modal class="so-modal" id="modal-{{ id }}" trigger-selector="{{ trigger_selector }}">
  <div class="so-modal__panel" data-modal-panel role="dialog" aria-modal="true" aria-labelledby="modal-title-{{ id }}">
    <h2 class="so-modal__title" id="modal-title-{{ id }}">{{ title | escape }}</h2>
    <div class="so-modal__content">
      {{ content }}
    </div>
    <button class="so-modal__close so-button so-button--ghost" type="button" data-modal-close aria-label="{{ 'general.modal.close' | t }}">
      &times;
    </button>
  </div>
</so-modal>
