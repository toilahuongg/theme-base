{% comment %}
  @param product {product}
  @param section_id {string}
{% endcomment %}

{% if product != blank and product.has_only_default_variant == false %}
  {% assign product_form_id = 'so-product-form-' | append: section_id %}

  <so-variant-controller class="so-variant-picker" product-form-id="{{ product_form_id }}">
    {% for option in product.options_with_values %}
      <fieldset class="so-variant-picker__group">
        <legend class="so-variant-picker__legend">{{ option.name | escape }}</legend>
        <div class="so-variant-picker__values">
          {% for value in option.values %}
            {% assign input_id = section_id | append: '-' | append: option.position | append: '-' | append: forloop.index %}
            <label class="so-variant-picker__value" for="{{ input_id }}">
              <input
                id="{{ input_id }}"
                class="so-variant-picker__input"
                type="radio"
                name="options[{{ option.name | escape }}]"
                value="{{ value | escape }}"
                data-variant-option
                {% if option.selected_value == value %}checked{% endif %}
              >
              <span>{{ value | escape }}</span>
            </label>
          {% endfor %}
        </div>
      </fieldset>
    {% endfor %}

    <script type="application/json" data-variant-json>
      {{ product.variants | json }}
    </script>
  </so-variant-controller>
{% endif %}
