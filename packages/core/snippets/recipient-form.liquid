{% comment %}
  @param product {product} Shopify product object
  @param form_id {string} Form ID for variant controller
{% endcomment %}

<so-recipient-form class="so-recipient-form">
  <label class="so-recipient-form__toggle">
    <input type="checkbox" name="properties[__is_gift]" value="true" data-recipient-toggle>
    {{ 'products.product.recipient.is_gift' | t }}
  </label>

  <div class="so-recipient-form__fields" data-recipient-fields hidden>
    <div class="so-recipient-form__group">
      <label for="recipient-name-{{ form_id }}" class="so-recipient-form__label">
        {{ 'products.product.recipient.name' | t }}
      </label>
      <input
        id="recipient-name-{{ form_id }}"
        class="so-recipient-form__input"
        type="text"
        name="properties[Recipient name]"
        autocomplete="name"
      >
    </div>

    <div class="so-recipient-form__group">
      <label for="recipient-email-{{ form_id }}" class="so-recipient-form__label">
        {{ 'products.product.recipient.email' | t }}
      </label>
      <input
        id="recipient-email-{{ form_id }}"
        class="so-recipient-form__input"
        type="email"
        name="properties[Recipient email]"
        autocomplete="email"
      >
    </div>

    <div class="so-recipient-form__group">
      <label for="recipient-message-{{ form_id }}" class="so-recipient-form__label">
        {{ 'products.product.recipient.message' | t }}
      </label>
      <textarea
        id="recipient-message-{{ form_id }}"
        class="so-recipient-form__input"
        name="properties[Recipient message]"
        rows="3"
      ></textarea>
    </div>

    <div class="so-recipient-form__group">
      <label for="recipient-date-{{ form_id }}" class="so-recipient-form__label">
        {{ 'products.product.recipient.delivery_date' | t }}
      </label>
      <input
        id="recipient-date-{{ form_id }}"
        class="so-recipient-form__input"
        type="date"
        name="properties[Delivery date]"
      >
    </div>
  </div>
</so-recipient-form>
