{% doc %}
Renders a configurable stack that can nest theme and app blocks.
@example
{% content_for 'block', type: 'content-stack', id: 'content-stack' %}
{% enddoc %}

<div class="so-content-stack so-content-stack--{{ block.settings.alignment }}" style="--so-content-stack-gap: {{ block.settings.gap }}px" {{ block.shopify_attributes }}>
  {% content_for 'blocks' %}
</div>

{% stylesheet %}
  .so-content-stack {
    display: grid;
    gap: var(--so-content-stack-gap);
  }

  .so-content-stack--left {
    justify-items: start;
    text-align: left;
  }

  .so-content-stack--center {
    justify-items: center;
    text-align: center;
  }

  .so-content-stack--stretch {
    justify-items: stretch;
    text-align: left;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Content stack",
  "blocks": [
    {
      "type": "@theme"
    },
    {
      "type": "@app"
    }
  ],
  "settings": [
    {
      "type": "range",
      "id": "gap",
      "label": "Gap",
      "min": 8,
      "max": 48,
      "step": 4,
      "unit": "px",
      "default": 16
    },
    {
      "type": "select",
      "id": "alignment",
      "label": "Alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "stretch",
          "label": "Stretch"
        }
      ],
      "default": "stretch"
    }
  ],
  "presets": [
    {
      "name": "Content stack",
      "blocks": [
        {
          "type": "callout-card"
        }
      ]
    }
  ]
}
{% endschema %}
