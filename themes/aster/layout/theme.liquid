<!doctype html>
<html lang="{{ request.locale.iso_code }}">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <title>
      {{ page_title }}
      {%- if current_tags -%} - {{ current_tags | join: ', ' }}{% endif -%}
      {%- if current_page != 1 -%} - Page {{ current_page }}{% endif -%}
      {%- unless page_title contains shop.name -%} - {{ shop.name }}{% endunless -%}
    </title>
    {{ content_for_header }}
    {{ 'so.css' | asset_url | stylesheet_tag }}
    <script src="{{ 'theme-components.js' | asset_url }}" defer></script>
  </head>
  <body>
    <a class="so-skip-link" href="#MainContent">{{ 'accessibility.skip_to_text' | t }}</a>
    {% section 'header' %}
    {% section 'cart-drawer' %}
    {% render 'quick-view' %}
    {% render 'live-region' %}

    <main id="MainContent" role="main">
      {{ content_for_layout }}
    </main>

    {% section 'footer' %}

    <so-back-to-top class="so-back-to-top" aria-label="{{ 'general.pagination.previous' | t }}">
      &uarr;
    </so-back-to-top>
  </body>
</html>
