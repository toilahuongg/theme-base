{% comment %}
  Blog article page section.
{% endcomment %}

<article class="so-section">
  <div class="so-page-width" style="max-width:48rem;">
    {% unless article.title == blank %}
      <h1 class="so-section__heading" style="font-size:clamp(1.75rem, 4vw, 3rem); margin-bottom:var(--so-space-md);">
        {{ article.title | escape }}
      </h1>
    {% endunless %}

    <div style="display:flex; gap:var(--so-space-md); align-items:center; margin-bottom:var(--so-space-xl); color:var(--so-color-text-faint); font-size:var(--so-text-sm);">
      {% if article.author != blank %}
        <span>{{ 'article.author_by' | t: author: article.author }}</span>
      {% endif %}
      <span>&middot;</span>
      <time datetime="{{ article.published_at | date: '%Y-%m-%d' }}">
        {{ article.published_at | date: '%B %d, %Y' }}
      </time>
      {% if article.comments_count > 0 %}
        <span>&middot;</span>
        <a href="#comments">{{ 'article.comments_count' | t: count: article.comments_count }}</a>
      {% endif %}
    </div>

    {% if article.image != blank %}
      <div style="margin-bottom:var(--so-space-xl); overflow:clip; border-radius:var(--so-radius);">
        {% render 'responsive-image', image: article.image, class: '', alt: article.image.alt, style: 'width:100%;aspect-ratio:16/9;object-fit:cover;' %}
      </div>
    {% endif %}

    <div class="so-prose rte">
      {{ article.content }}
    </div>

    {% if article.tags.size > 0 %}
      <div style="margin-top:var(--so-space-2xl); display:flex; flex-wrap:wrap; gap:var(--so-space-xs);">
        {% for tag in article.tags %}
          <span class="so-badge so-badge--neutral">{{ tag }}</span>
        {% endfor %}
      </div>
    {% endif %}

    {% if blog.comments_enabled? %}
      <div id="comments" style="margin-top:var(--so-space-3xl);">
        <h2 style="font-size:var(--so-text-xl); margin-bottom:var(--so-space-lg);">{{ 'article.comments' | t }}</h2>

        {% if article.comments_count > 0 %}
          {% for comment in article.comments %}
            <div style="padding:var(--so-space-lg) 0; border-block-end:1px solid var(--so-color-border);">
              <p style="font-size:var(--so-text-sm); color:var(--so-color-text-faint); margin:0 0 var(--so-space-xs);">
                {{ comment.author }} &middot; {{ comment.created_at | date: '%B %d, %Y' }}
              </p>
              <div class="so-prose" style="margin:0;">
                {{ comment.content }}
              </div>
            </div>
          {% endfor %}
        {% endif %}

        {% form 'new_comment', article %}
          {{ form.errors | default_errors }}
          <div style="display:grid; gap:var(--so-space-md); margin-top:var(--so-space-xl);">
            <div>
              <label for="comment-author" class="so-product-form__label">{{ 'article.comment_name' | t }}</label>
              <input id="comment-author" class="so-predictive-search__input" type="text" name="comment[author]" required>
            </div>
            <div>
              <label for="comment-email" class="so-product-form__label">{{ 'article.comment_email' | t }}</label>
              <input id="comment-email" class="so-predictive-search__input" type="email" name="comment[email]" required>
            </div>
            <div>
              <label for="comment-body" class="so-product-form__label">{{ 'article.comment_body' | t }}</label>
              <textarea id="comment-body" class="so-predictive-search__input" name="comment[body]" rows="5" required></textarea>
            </div>
            <button class="so-button" type="submit">{{ 'article.comment_submit' | t }}</button>
          </div>
          {% if form.posted_successfully? %}
            <p class="so-newsletter__success">{{ 'article.comment_success' | t }}</p>
          {% endif %}
        {% endform %}
      </div>
    {% endif %}
  </div>
</article>

{% schema %}
{
  "name": "Article",
  "tag": "article"
}
{% endschema %}
