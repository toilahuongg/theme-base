{% comment %}
  Image with text section - classic split layout.
{% endcomment %}
<section class="so-section" id="shopify-section-{{ section.id }}">
  <div class="so-page-width">
    <div class="so-image-with-text" style="display:grid; gap:clamp(1.5rem, 4vw, 3rem); grid-template-columns: 1fr 1fr;">
      {% if section.settings.image_position == 'right' %}
        <div class="so-image-with-text__content" style="display:grid; gap:var(--so-space-md); align-self:center;">
          {% if section.settings.eyebrow != blank %}
            <p class="so-image-with-text__eyebrow" style="color:var(--so-color-accent); font-size:var(--so-text-sm); font-weight:700; letter-spacing:var(--so-tracking-wide); text-transform:uppercase;">
              {{ section.settings.eyebrow | escape }}
            </p>
          {% endif %}

          {% if section.settings.heading != blank %}
            <h2 class="so-section__heading" style="font-size:clamp(1.5rem, 3vw, 2.25rem);">
              {{ section.settings.heading | escape }}
            </h2>
          {% endif %}

          {% if section.settings.text != blank %}
            <div class="so-prose" style="color:var(--so-color-text-soft);">
              {{ section.settings.text }}
            </div>
          {% endif %}

          {% if section.settings.button_text != blank %}
            <div>
              {% render 'button', text: section.settings.button_text, url: section.settings.button_url, style: section.settings.button_style %}
            </div>
          {% endif %}
        </div>

        <div class="so-image-with-text__image" style="align-self:center;">
          {% if section.settings.image != blank %}
            {% render 'responsive-image', image: section.settings.image, class: '', alt: section.settings.image.alt %}
          {% else %}
            <div class="so-skeleton so-skeleton--image" style="min-height:20rem;"></div>
          {% endif %}
        </div>
      {% else %}
        <div class="so-image-with-text__image" style="align-self:center;">
          {% if section.settings.image != blank %}
            {% render 'responsive-image', image: section.settings.image, class: '', alt: section.settings.image.alt %}
          {% else %}
            <div class="so-skeleton so-skeleton--image" style="min-height:20rem;"></div>
          {% endif %}
        </div>

        <div class="so-image-with-text__content" style="display:grid; gap:var(--so-space-md); align-self:center;">
          {% if section.settings.eyebrow != blank %}
            <p class="so-image-with-text__eyebrow" style="color:var(--so-color-accent); font-size:var(--so-text-sm); font-weight:700; letter-spacing:var(--so-tracking-wide); text-transform:uppercase;">
              {{ section.settings.eyebrow | escape }}
            </p>
          {% endif %}

          {% if section.settings.heading != blank %}
            <h2 class="so-section__heading" style="font-size:clamp(1.5rem, 3vw, 2.25rem);">
              {{ section.settings.heading | escape }}
            </h2>
          {% endif %}

          {% if section.settings.text != blank %}
            <div class="so-prose" style="color:var(--so-color-text-soft);">
              {{ section.settings.text }}
            </div>
          {% endif %}

          {% if section.settings.button_text != blank %}
            <div>
              {% render 'button', text: section.settings.button_text, url: section.settings.button_url, style: section.settings.button_style %}
            </div>
          {% endif %}
        </div>
      {% endif %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Image with text",
  "tag": "section",
  "settings": [
    { "type": "image_picker", "id": "image", "label": "Image" },
    { "type": "select", "id": "image_position", "label": "Image position", "options": [
      { "value": "left", "label": "Left" },
      { "value": "right", "label": "Right" }
    ], "default": "left" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Image with text" },
    { "type": "richtext", "id": "text", "label": "Description", "default": "<p>Pair large text with an image to tell a story.</p>" },
    { "type": "text", "id": "button_text", "label": "Button label" },
    { "type": "url", "id": "button_url", "label": "Button link" },
    { "type": "select", "id": "button_style", "label": "Button style", "options": [
      { "value": "primary", "label": "Primary" },
      { "value": "secondary", "label": "Secondary" }
    ], "default": "primary" }
  ],
  "presets": [{ "name": "Image with text" }]
}
{% endschema %}
