{% comment %}
  Collection list section - showcase featured collections.
{% endcomment %}

<section class="so-section" id="shopify-section-{{ section.id }}">
  <div class="so-page-width">
    {% if section.settings.heading != blank %}
      <div class="so-section__header">
        <h2 class="so-section__heading">{{ section.settings.heading | escape }}</h2>
      </div>
    {% endif %}

    <div class="so-product-grid">
      {% for block in section.blocks %}
        {% assign collection = block.settings.collection %}
        {% if collection != blank %}
          <a class="so-card so-collection-card" href="{{ collection.url }}" style="text-decoration:none; display:block; overflow:clip;">
            {% if collection.image != blank or collection.featured_image != blank %}
              <div class="so-card__media">
                {% assign image = collection.image | default: collection.featured_image %}
                {% render 'responsive-image', image: image, class: '', alt: collection.title %}
              </div>
            {% else %}
              <div class="so-card__media so-card__placeholder">
                {{ 'general.collection.placeholder' | t }}
              </div>
            {% endif %}
            <div class="so-card__content">
              <h3 class="so-card__title">{{ collection.title | escape }}</h3>
              {% if collection.description != blank %}
                <p style="color:var(--so-color-text-soft); font-size:var(--so-text-sm); margin:0;">
                  {{ collection.description | strip_html | truncate: 100 }}
                </p>
              {% endif %}
              {% if collection.products_count > 0 %}
                <p style="color:var(--so-color-text-faint); font-size:var(--so-text-xs); margin:0;">
                  {{ 'general.collection.product_count' | t: count: collection.products_count }}
                </p>
              {% endif %}
            </div>
          </a>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Collection list",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Shop by collection" },
    { "type": "range", "id": "columns_desktop", "label": "Columns on desktop", "min": 2, "max": 4, "step": 1, "default": 3 }
  ],
  "blocks": [
    {
      "type": "collection",
      "name": "Collection",
      "settings": [
        { "type": "collection", "id": "collection", "label": "Collection" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Collection list",
      "blocks": [
        { "type": "collection" },
        { "type": "collection" },
        { "type": "collection" }
      ]
    }
  ]
}
{% endschema %}
