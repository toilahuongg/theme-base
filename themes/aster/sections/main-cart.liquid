<section class="so-section so-cart-page">
  <div class="so-page-width">
    <header class="so-section__header">
      <h1 class="so-section__heading">{{ 'cart.general.title' | t }}</h1>
    </header>

    <so-cart-items class="so-cart-page__items" currency="{{ cart.currency.iso_code | default: shop.currency }}">
      <ul class="so-cart-lines" role="list" data-cart-lines {% if cart.item_count == 0 %}hidden{% endif %}>
        {% for item in cart.items %}
          {% render 'cart-line-item', item: item, line_index: forloop.index %}
        {% endfor %}
      </ul>

      <div class="so-cart-page__summary" data-cart-summary {% if cart.item_count == 0 %}hidden{% endif %}>
        <div class="so-cart-page__subtotal">
          <span>{{ 'cart.general.subtotal' | t }}</span>
          <strong data-cart-subtotal>{{ cart.total_price | money }}</strong>
        </div>
        <a class="so-button" href="{{ routes.checkout_url }}">{{ 'cart.general.checkout' | t }}</a>
      </div>

      <div class="so-cart-page__empty" data-cart-empty {% if cart.item_count > 0 %}hidden{% endif %}>
        <p>{{ 'cart.general.empty' | t }}</p>
        <a class="so-button" href="{{ routes.all_products_collection_url }}">{{ 'cart.general.continue_shopping' | t }}</a>
      </div>
    </so-cart-items>
  </div>
</section>

{% schema %}
{
  "name": "Main cart"
}
{% endschema %}
