{% comment %}
  Newsletter signup section.
{% endcomment %}

<section class="so-section" id="shopify-section-{{ section.id }}" style="background:var(--so-color-surface-muted); border-radius:var(--so-radius);">
  <div class="so-page-width" style="text-align:center; display:grid; gap:var(--so-space-lg); max-width:36rem; margin-inline:auto;">
    {% if section.settings.eyebrow != blank %}
      <p class="so-section__eyebrow" style="color:var(--so-color-accent); font-size:var(--so-text-sm); font-weight:700; letter-spacing:var(--so-tracking-wide); text-transform:uppercase; margin:0;">
        {{ section.settings.eyebrow | escape }}
      </p>
    {% endif %}

    {% if section.settings.heading != blank %}
      <h2 class="so-section__heading" style="font-size:clamp(1.5rem, 3vw, 2.25rem); margin:0;">
        {{ section.settings.heading | escape }}
      </h2>
    {% endif %}

    {% if section.settings.text != blank %}
      <p class="so-section__text" style="margin:0;">
        {{ section.settings.text | escape }}
      </p>
    {% endif %}

    {% form 'customer', class: 'so-newsletter', style: 'max-width:28rem; margin-inline:auto;' %}
      {{ form.errors | default_errors }}
      <div class="so-newsletter__form">
        <input
          type="email"
          name="contact[email]"
          class="so-newsletter__input"
          placeholder="{{ 'newsletter.placeholder' | t }}"
          aria-label="{{ 'newsletter.placeholder' | t }}"
          required
        >
        <button class="so-button" type="submit">{{ section.settings.button_text | default: 'newsletter.subscribe' | t }}</button>
      </div>
      {% if form.posted_successfully? %}
        <p class="so-newsletter__success">{{ 'newsletter.success' | t }}</p>
      {% endif %}
    {% endform %}
  </div>
</section>

{% schema %}
{
  "name": "Newsletter",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Newsletter" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Stay in the loop" },
    { "type": "text", "id": "text", "label": "Description", "default": "Get updates on new products, restocks, and exclusive offers." },
    { "type": "text", "id": "button_text", "label": "Button label", "default": "Subscribe" }
  ],
  "presets": [{ "name": "Newsletter" }]
}
{% endschema %}
