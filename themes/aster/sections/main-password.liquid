{% comment %}
  Password page section for stores behind password protection.
{% endcomment %}

<section class="so-section" style="min-height:100dvh; display:grid; place-items:center;">
  <div style="text-align:center; max-width:28rem; display:grid; gap:var(--so-space-lg);">
    <h1 style="font-size:clamp(1.5rem, 3vw, 2rem); letter-spacing:var(--so-tracking-tight);">
      {{ shop.name | escape }}
    </h1>

    {% if shop.password_message != blank %}
      <p style="color:var(--so-color-text-soft);">
        {{ shop.password_message }}
      </p>
    {% endif %}

    {% form 'storefront_password', class: 'so-newsletter' %}
      {{ form.errors | default_errors }}
      <div class="so-newsletter__form" style="flex-direction:column;">
        <input
          type="password"
          name="password"
          class="so-newsletter__input"
          placeholder="{{ 'password.enter' | t }}"
          aria-label="{{ 'password.enter' | t }}"
          required
        >
        <button class="so-button" type="submit">{{ 'password.submit' | t }}</button>
      </div>
    {% endform %}

    {% if section.settings.social_sharing %}
      {% render 'share', title: shop.name, url: shop.url %}
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Password",
  "tag": "section",
  "settings": [
    { "type": "checkbox", "id": "social_sharing", "label": "Show social sharing", "default": false }
  ]
}
{% endschema %}
