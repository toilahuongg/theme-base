<section class="so-section">
  <div class="so-page-width">
    <div class="so-section__header">
      {% if section.settings.heading != blank %}
        <h2 class="so-section__heading">{{ section.settings.heading | escape }}</h2>
      {% endif %}
      {% if section.settings.text != blank %}
        <div class="so-section__text rte">{{ section.settings.text }}</div>
      {% endif %}
    </div>

    <div class="so-section__blocks">
      {% content_for 'blocks' %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Rich content",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Story-led content"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text",
      "default": "<p>Add supporting copy, brand details, or educational content here.</p>"
    }
  ],
  "blocks": [
    {
      "type": "@theme"
    },
    {
      "type": "@app"
    }
  ],
  "presets": [
    {
      "name": "Rich content",
      "blocks": [
        {
          "type": "content-stack",
          "blocks": [
            {
              "type": "callout-card",
              "settings": {
                "eyebrow": "Proof point",
                "heading": "Merchandising that adapts to the story",
                "text": "<p>Add compact trust, education, or comparison content without creating a new section.</p>"
              }
            }
          ]
        }
      ]
    }
  ]
}
{% endschema %}
