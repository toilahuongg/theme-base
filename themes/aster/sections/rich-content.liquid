<section class="tb-section">
  <div class="tb-page-width">
    <div class="tb-section__header">
      {% if section.settings.heading != blank %}
        <h2 class="tb-section__heading">{{ section.settings.heading | escape }}</h2>
      {% endif %}
      {% if section.settings.text != blank %}
        <div class="tb-section__text rte">{{ section.settings.text }}</div>
      {% endif %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Rich content",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Story-led content"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text",
      "default": "<p>Add supporting copy, brand details, or educational content here.</p>"
    }
  ],
  "presets": [
    {
      "name": "Rich content"
    }
  ]
}
{% endschema %}
