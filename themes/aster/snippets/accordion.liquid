{% comment %}
  @param items {array} Array of { heading, content } objects
  @param single_expand {boolean} Only one panel open at a time
  @param class {string} Additional CSS classes
{% endcomment %}

<div class="so-accordion {{ class }}">
  {% for item in items %}
    <div class="so-accordion__item" data-accordion-item>
      <button class="so-accordion__toggle" data-accordion-toggle aria-expanded="{% if item.expanded %}true{% else %}false{% endif %}">
        {{ item.heading | escape }}
      </button>
      <div class="so-accordion__panel" data-accordion-panel {% unless item.expanded %}hidden{% endunless %}>
        {{ item.content }}
      </div>
    </div>
  {% endfor %}
</div>
