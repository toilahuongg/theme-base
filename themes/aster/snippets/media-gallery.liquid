{% comment %}
  @param product {product}
{% endcomment %}

{% if product != blank %}
  {% assign selected_media = product.selected_or_first_available_variant.featured_media | default: product.featured_media %}
  <so-media-gallery class="so-media-gallery">
    <div class="so-media-gallery__stage">
      {% if product.media.size > 0 %}
        {% for media in product.media %}
          {% assign media_alt = media.alt | default: product.title | escape %}
          {% assign media_active = false %}
          {% if selected_media != blank and media.id == selected_media.id %}
            {% assign media_active = true %}
          {% elsif selected_media == blank and forloop.first %}
            {% assign media_active = true %}
          {% endif %}
          <div
            class="so-media-gallery__item"
            data-media-item="{{ media.id }}"
            {% unless media_active %}hidden{% endunless %}
          >
            {{ media.preview_image | image_url: width: 1800 | image_tag: class: 'so-media-gallery__image', loading: 'lazy', widths: '480, 720, 960, 1200, 1600, 1800', sizes: '(min-width: 990px) 50vw, 100vw', alt: media_alt }}
          </div>
        {% endfor %}
      {% else %}
        <div class="so-media-gallery__item" data-media-item="placeholder">
          {{ 'product-1' | placeholder_svg_tag: 'so-media-gallery__image so-media-gallery__image--placeholder' }}
        </div>
      {% endif %}
    </div>

    {% if product.media.size > 1 %}
      <div class="so-media-gallery__thumbnails" aria-label="{{ 'products.product.media_gallery' | t }}">
        {% for media in product.media %}
          {% assign thumbnail_alt = media.alt | default: product.title | escape %}
          {% assign thumbnail_active = false %}
          {% if selected_media != blank and media.id == selected_media.id %}
            {% assign thumbnail_active = true %}
          {% elsif selected_media == blank and forloop.first %}
            {% assign thumbnail_active = true %}
          {% endif %}
          <button
            class="so-media-gallery__thumbnail"
            type="button"
            data-media-thumbnail="{{ media.id }}"
            aria-current="{% if thumbnail_active %}true{% else %}false{% endif %}"
          >
            {{ media.preview_image | image_url: width: 180 | image_tag: loading: 'lazy', widths: '90, 180', sizes: '90px', alt: thumbnail_alt }}
          </button>
        {% endfor %}
      </div>
    {% endif %}
  </so-media-gallery>
{% endif %}
