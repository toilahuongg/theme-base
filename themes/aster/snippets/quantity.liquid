{% comment %}
  @param name {string} Input name attribute
  @param value {number} Current quantity value
  @param min {number} Minimum quantity
  @param max {number} Maximum quantity
  @param step {number} Step increment
  @param id {string} Input ID
{% endcomment %}

<div class="so-quantity" data-quantity>
  <button
    class="so-quantity__button so-quantity__decrease"
    type="button"
    data-quantity-decrease
    aria-label="{{ 'cart.quantity.decrease' | t }}"
  >
    &minus;
  </button>
  <input
    class="so-quantity__input"
    type="number"
    name="{{ name }}"
    id="{{ id }}"
    value="{{ value | default: 1 }}"
    min="{{ min | default: 1 }}"
    max="{{ max }}"
    step="{{ step | default: 1 }}"
    aria-label="{{ 'cart.quantity.label' | t }}"
  >
  <button
    class="so-quantity__button so-quantity__increase"
    type="button"
    data-quantity-increase
    aria-label="{{ 'cart.quantity.increase' | t }}"
  >
    &plus;
  </button>
</div>
