{% doc %}
Renders a compact callout card for theme block zones.
@example
{% content_for 'block', type: 'callout-card', id: 'callout-card' %}
{% enddoc %}

<article class="tb-callout-card tb-callout-card--{{ block.settings.tone }}" {{ block.shopify_attributes }}>
  {% if block.settings.eyebrow != blank %}
    <p class="tb-callout-card__eyebrow">{{ block.settings.eyebrow | escape }}</p>
  {% endif %}

  {% if block.settings.heading != blank %}
    <h3 class="tb-callout-card__heading">{{ block.settings.heading | escape }}</h3>
  {% endif %}

  {% if block.settings.text != blank %}
    <div class="tb-callout-card__text rte">{{ block.settings.text }}</div>
  {% endif %}

  {% if block.settings.link_label != blank and block.settings.link_url != blank %}
    <a class="tb-callout-card__link" href="{{ block.settings.link_url }}">{{ block.settings.link_label | escape }}</a>
  {% endif %}
</article>

{% stylesheet %}
  .tb-callout-card {
    border: 1px solid rgba(20, 20, 20, 0.12);
    border-radius: var(--tb-radius);
    display: grid;
    gap: 0.75rem;
    padding: 1.25rem;
  }

  .tb-callout-card--accent {
    background: color-mix(in srgb, var(--tb-color-accent) 10%, var(--tb-color-surface));
    border-color: color-mix(in srgb, var(--tb-color-accent) 30%, transparent);
  }

  .tb-callout-card--surface {
    background: var(--tb-color-surface);
  }

  .tb-callout-card__eyebrow {
    color: var(--tb-color-accent);
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0;
    margin: 0;
    text-transform: uppercase;
  }

  .tb-callout-card__heading {
    font-size: clamp(1.2rem, 2vw, 1.65rem);
    line-height: 1.15;
    margin: 0;
  }

  .tb-callout-card__text {
    color: color-mix(in srgb, var(--tb-color-text) 75%, transparent);
  }

  .tb-callout-card__link {
    color: var(--tb-color-accent);
    font-weight: 700;
    text-underline-offset: 0.2em;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Callout card",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Proof point"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Add a focused merchandising callout"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text",
      "default": "<p>Use this block for benefits, comparison notes, editorial context, or trust messaging.</p>"
    },
    {
      "type": "text",
      "id": "link_label",
      "label": "Link label"
    },
    {
      "type": "url",
      "id": "link_url",
      "label": "Link"
    },
    {
      "type": "select",
      "id": "tone",
      "label": "Tone",
      "options": [
        {
          "value": "surface",
          "label": "Surface"
        },
        {
          "value": "accent",
          "label": "Accent"
        }
      ],
      "default": "surface"
    }
  ],
  "presets": [
    {
      "name": "Callout card"
    }
  ]
}
{% endschema %}
