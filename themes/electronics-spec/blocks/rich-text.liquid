{% comment %}
  Rich text block - centered heading + description + optional CTA.
  For use inside sections.
{% endcomment %}

<div class="so-rich-text" style="text-align:center; max-width:65ch; margin-inline:auto; display:grid; gap:var(--so-space-md);" {% render 'block-shopify-attrs', block: block %}>
  {% if block.settings.heading != blank %}
    <{{ block.settings.heading_tag | default: 'h2' }} class="so-rich-text__heading" style="font-size:clamp(1.25rem, 2vw, 1.75rem); line-height:var(--so-leading-tight); letter-spacing:var(--so-tracking-tight);">
      {{ block.settings.heading | escape }}
    </{{ block.settings.heading_tag | default: 'h2' }}>
  {% endif %}

  {% if block.settings.text != blank %}
    <div class="so-rich-text__content so-prose" style="margin:0; text-align:left;">
      {{ block.settings.text }}
    </div>
  {% endif %}

  {% if block.settings.button_label != blank %}
    <div>
      {% render 'button', text: block.settings.button_label, url: block.settings.button_url, style: block.settings.button_style %}
    </div>
  {% endif %}
</div>

{% schema %}
{
  "type": "rich-text",
  "name": "Rich text",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading" },
    { "type": "select", "id": "heading_tag", "label": "Heading size", "options": [
      { "value": "h2", "label": "Large" },
      { "value": "h3", "label": "Medium" },
      { "value": "p", "label": "Small" }
    ], "default": "h2" },
    { "type": "richtext", "id": "text", "label": "Description" },
    { "type": "text", "id": "button_label", "label": "Button label" },
    { "type": "url", "id": "button_url", "label": "Button link" },
    { "type": "select", "id": "button_style", "label": "Button style", "options": [
      { "value": "primary", "label": "Primary" },
      { "value": "secondary", "label": "Secondary" }
    ], "default": "primary" }
  ]
}
{% endschema %}
