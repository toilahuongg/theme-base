{% comment %}
  Featured collection block - for use inside sections that support blocks.
  Renders a collection title, description, and product grid.
{% endcomment %}

{% assign collection = block.settings.collection %}
{% if collection != blank %}
  <div class="so-featured-collection" {% render 'block-shopify-attrs', block: block %}>
    {% if block.settings.show_title and collection.title != blank %}
      <h3 class="so-featured-collection__title" style="margin:0 0 var(--so-space-sm); font-size:var(--so-text-lg); letter-spacing:var(--so-tracking-tight);">
        {{ collection.title | escape }}
      </h3>
    {% endif %}

    {% if block.settings.show_description and collection.description != blank %}
      <p class="so-featured-collection__desc" style="margin:0 0 var(--so-space-md); color:var(--so-color-text-soft); font-size:var(--so-text-sm);">
        {{ collection.description | strip_html | truncate: 150 }}
      </p>
    {% endif %}

    <div class="so-grid so-product-grid" style="grid-template-columns: repeat(auto-fit, minmax(min(100%, 14rem), 1fr));">
      {% for product in collection.products limit: block.settings.products_count %}
        {% render 'product-card', product: product %}
      {% endfor %}
    </div>

    {% if block.settings.show_view_all %}
      <div style="margin-top:var(--so-space-lg); text-align:center;">
        <a class="so-button so-button--secondary" href="{{ collection.url }}">
          {{ 'general.collection.view_all' | t }}
        </a>
      </div>
    {% endif %}
  </div>
{% endif %}

{% schema %}
{
  "type": "featured-collection",
  "name": "Featured collection",
  "settings": [
    { "type": "collection", "id": "collection", "label": "Collection" },
    { "type": "checkbox", "id": "show_title", "label": "Show collection title", "default": true },
    { "type": "checkbox", "id": "show_description", "label": "Show description", "default": true },
    { "type": "range", "id": "products_count", "label": "Products to show", "min": 1, "max": 12, "step": 1, "default": 4 },
    { "type": "checkbox", "id": "show_view_all", "label": "Show view all link", "default": true }
  ]
}
{% endschema %}
