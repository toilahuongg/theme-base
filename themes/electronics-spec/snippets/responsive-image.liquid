{% comment %}
  @param image {image}
  @param class {string}
  @param alt {string}
{% endcomment %}

{% if image != blank %}
  {% assign alt_text = alt | default: image.alt | escape %}
  {{ image | image_url: width: 1600 | image_tag: class: class, alt: alt_text, loading: 'lazy', widths: '320, 480, 640, 800, 960, 1200, 1600', sizes: '(min-width: 750px) 50vw, 100vw' }}
{% else %}
  {{ 'image' | placeholder_svg_tag: class }}
{% endif %}
