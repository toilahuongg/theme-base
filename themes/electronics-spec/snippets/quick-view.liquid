{% comment %}
  Quick view modal shell. Content is loaded dynamically via so:quick-view:open event.
{% endcomment %}

<so-quick-view class="so-quick-view" trigger-selector="[data-quick-view-open]">
  <div class="so-quick-view__panel" data-quick-view-panel>
    <button class="so-quick-view__close so-modal__close" data-quick-view-close aria-label="{{ 'general.quick_view.close' | t }}">
      &times;
    </button>
    <div class="so-quick-view__content" data-quick-view-content>
      <div class="so-empty-state">
        <p>{{ 'general.quick_view.loading' | t }}</p>
      </div>
    </div>
  </div>
</so-quick-view>
