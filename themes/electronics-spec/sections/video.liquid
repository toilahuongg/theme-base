{% comment %}
  Full-width or contained video section.
{% endcomment %}

<section class="so-section" id="shopify-section-{{ section.id }}">
  <div class="so-page-width">
    {% if section.settings.heading != blank %}
      <div class="so-section__header">
        <h2 class="so-section__heading">{{ section.settings.heading | escape }}</h2>
      </div>
    {% endif %}

    <div class="so-video" style="overflow:clip; border-radius:var(--so-radius); border:1px solid var(--so-color-border); background:var(--so-color-surface); aspect-ratio: 16/9;">
      {% if section.settings.video_url != blank %}
        <so-deferred-media class="so-deferred-media">
          {% if section.settings.cover_image != blank %}
            <div class="so-deferred-media__frame" style="position:relative; width:100%; height:100%;">
              {% render 'responsive-image', image: section.settings.cover_image, class: '', alt: section.settings.heading, style: 'width:100%;height:100%;object-fit:cover;' %}
              <button class="so-button so-button--ghost" type="button" data-deferred-media-load aria-label="{{ 'general.media.play' | t }}" style="position:absolute; top:50%; left:50%; transform:translate(-50%, -50%);">
                {{ 'general.media.play' | t }}
              </button>
            </div>
          {% else %}
            <div class="so-deferred-media__frame" style="display:grid; place-items:center; width:100%; height:100%;">
              <button class="so-button" type="button" data-deferred-media-load aria-label="{{ 'general.media.play' | t }}">
                {{ 'general.media.play' | t }}
              </button>
            </div>
          {% endif %}
          <template>
            {% if section.settings.video_url contains 'youtube' %}
              <iframe src="{{ section.settings.video_url | replace: 'watch?v=', 'embed/' }}?autoplay=1&rel=0" frameborder="0" allow="autoplay; encrypted-media" allowfullscreen style="width:100%;height:100%;"></iframe>
            {% elsif section.settings.video_url contains 'vimeo' %}
              <iframe src="{{ section.settings.video_url }}/embed?autoplay=1" frameborder="0" allow="autoplay" allowfullscreen style="width:100%;height:100%;"></iframe>
            {% else %}
              <video controls autoplay muted playsinline style="width:100%;height:100%;object-fit:cover;">
                <source src="{{ section.settings.video_url }}">
              </video>
            {% endif %}
          </template>
        </so-deferred-media>
      {% endif %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Video",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading" },
    { "type": "text", "id": "video_url", "label": "Video URL (YouTube, Vimeo, or direct .mp4)" },
    { "type": "image_picker", "id": "cover_image", "label": "Cover image" },
    { "type": "checkbox", "id": "full_width", "label": "Full width", "default": false }
  ],
  "presets": [{ "name": "Video" }]
}
{% endschema %}
