{% comment %}
  Collage section - mixed media layout with images, videos, and product cards.
{% endcomment %}

<section class="so-section" id="shopify-section-{{ section.id }}">
  <div class="so-page-width">
    {% if section.settings.heading != blank %}
      <div class="so-section__header">
        <h2 class="so-section__heading">{{ section.settings.heading | escape }}</h2>
      </div>
    {% endif %}

    <div class="so-collage" style="display:grid; gap:var(--so-space-md); grid-template-columns: repeat(4, 1fr); grid-auto-rows:minmax(12rem, auto);">
      {% for block in section.blocks %}
        {% case block.type %}
          {% when 'image' %}
            <div class="so-collage__item"
              style="grid-column: span {{ block.settings.width | default: 2 }}; grid-row: span {{ block.settings.height | default: 1 }}; overflow:clip; border-radius:var(--so-radius); border:1px solid var(--so-color-border);"
              {% render 'block-shopify-attrs', block: block %}
            >
              {% if block.settings.image != blank %}
                {% render 'responsive-image', image: block.settings.image, class: 'so-collage__image', alt: block.settings.image.alt, style: 'width:100%;height:100%;object-fit:cover;' %}
              {% else %}
                <div class="so-skeleton so-skeleton--image"></div>
              {% endif %}
            </div>

          {% when 'product' %}
            {% assign product = block.settings.product %}
            {% if product != blank %}
              <div class="so-collage__item so-collage__item--product"
                style="grid-column: span {{ block.settings.width | default: 2 }}; grid-row: span {{ block.settings.height | default: 1 }}; overflow:clip; border-radius:var(--so-radius); border:1px solid var(--so-color-border); background:var(--so-color-surface); display:grid; gap:var(--so-space-md); padding:var(--so-space-md);"
                {% render 'block-shopify-attrs', block: block %}
              >
                <a href="{{ product.url }}" style="overflow:clip; border-radius:var(--so-radius-small);">
                  {% if product.featured_image != blank %}
                    {% render 'responsive-image', image: product.featured_image, class: '', alt: product.title, style: 'width:100%;aspect-ratio:1/1;object-fit:cover;' %}
                  {% endif %}
                </a>
                <div>
                  <h3 class="so-card__title"><a href="{{ product.url }}">{{ product.title | escape }}</a></h3>
                  {% render 'price', price: product.selected_or_first_available_variant.price, compare_at_price: product.selected_or_first_available_variant.compare_at_price %}
                </div>
              </div>
            {% endif %}

          {% when 'video' %}
            <div class="so-collage__item"
              style="grid-column: span {{ block.settings.width | default: 2 }}; grid-row: span {{ block.settings.height | default: 1 }}; overflow:clip; border-radius:var(--so-radius);"
              {% render 'block-shopify-attrs', block: block %}
            >
              {% if block.settings.video_url != blank %}
                <so-deferred-media class="so-deferred-media" data-media-id="{{ block.settings.video_url }}">
                  <div class="so-deferred-media__frame" style="position:relative; width:100%; height:100%;">
                    <button class="so-button so-button--ghost" type="button" data-deferred-media-load aria-label="{{ 'general.media.play' | t }}">
                      {{ 'general.media.play' | t }}
                    </button>
                  </div>
                  <template>
                    {% if block.settings.video_url contains 'youtube' %}
                      <iframe src="{{ block.settings.video_url | replace: 'watch?v=', 'embed/' }}" frameborder="0" allowfullscreen style="width:100%;height:100%;"></iframe>
                    {% elsif block.settings.video_url contains 'vimeo' %}
                      <iframe src="{{ block.settings.video_url }}/embed" frameborder="0" allowfullscreen style="width:100%;height:100%;"></iframe>
                    {% endif %}
                  </template>
                </so-deferred-media>
              {% endif %}
            </div>

          {% when 'text' %}
            <div class="so-collage__item so-collage__item--text"
              style="grid-column: span {{ block.settings.width | default: 2 }}; grid-row: span {{ block.settings.height | default: 1 }}; display:grid; place-items:center; padding:var(--so-space-lg); border-radius:var(--so-radius); border:1px solid var(--so-color-border); background:var(--so-color-surface-muted); text-align:center;"
              {% render 'block-shopify-attrs', block: block %}
            >
              <div>
                {% if block.settings.text != blank %}
                  {{ block.settings.text }}
                {% endif %}
              </div>
            </div>
        {% endcase %}
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Collage",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading" }
  ],
  "blocks": [
    {
      "type": "image",
      "name": "Image",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "range", "id": "width", "label": "Width (columns)", "min": 1, "max": 4, "step": 1, "default": 2 },
        { "type": "range", "id": "height", "label": "Height (rows)", "min": 1, "max": 3, "step": 1, "default": 1 }
      ]
    },
    {
      "type": "product",
      "name": "Product",
      "settings": [
        { "type": "product", "id": "product", "label": "Product" },
        { "type": "range", "id": "width", "label": "Width (columns)", "min": 1, "max": 4, "step": 1, "default": 2 },
        { "type": "range", "id": "height", "label": "Height (rows)", "min": 1, "max": 3, "step": 1, "default": 1 }
      ]
    },
    {
      "type": "video",
      "name": "Video",
      "settings": [
        { "type": "text", "id": "video_url", "label": "Video URL (YouTube or Vimeo)" },
        { "type": "range", "id": "width", "label": "Width (columns)", "min": 1, "max": 4, "step": 1, "default": 2 },
        { "type": "range", "id": "height", "label": "Height (rows)", "min": 1, "max": 3, "step": 1, "default": 1 }
      ]
    },
    {
      "type": "text",
      "name": "Text",
      "settings": [
        { "type": "richtext", "id": "text", "label": "Text content" },
        { "type": "range", "id": "width", "label": "Width (columns)", "min": 1, "max": 4, "step": 1, "default": 2 },
        { "type": "range", "id": "height", "label": "Height (rows)", "min": 1, "max": 2, "step": 1, "default": 1 }
      ]
    }
  ],
  "presets": [
    {
      "name": "Collage",
      "blocks": [
        { "type": "image", "settings": { "width": 2, "height": 1 } },
        { "type": "product", "settings": { "width": 2, "height": 1 } },
        { "type": "video", "settings": { "width": 4, "height": 2 } }
      ]
    }
  ]
}
{% endschema %}
